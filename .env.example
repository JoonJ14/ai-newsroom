# AI Newsroom — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Supabase (required) ─────────────────────────────────────
# Get these from your Supabase project dashboard: Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Digest Delivery (pick one adapter) ──────────────────────

# Discord
DISCORD_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack
SLACK_WEBHOOK_URL=

# iMessage (macOS only — use phone number or Apple ID email)
IMESSAGE_RECIPIENT=

# ─── Optional ────────────────────────────────────────────────

# Claude API key — enables AI-generated summary at the top of each digest
ANTHROPIC_API_KEY=

# GitHub token — higher rate limits for GitHub API collectors
GITHUB_TOKEN=
